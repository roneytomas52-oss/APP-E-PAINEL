<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E1117"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/offerType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tipo"
        android:textColor="#9CA3AF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/offerTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Nova oferta"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/offerId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Oferta #"
        android:textColor="#E5E7EB"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/offerMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Módulo"
        android:textColor="#D1D5DB"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/offerBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Detalhes"
        android:textColor="#F9FAFB"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/offerExpireState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Expira em breve"
        android:textColor="#FBBF24"
        android:textSize="16sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/offerAcceptButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#16A34A"
        android:text="Aceitar"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/offerDeclineButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="#B91C1C"
        android:text="Recusar"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/offerCloseButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="Fechar"
        android:textColor="#9CA3AF"
        android:textSize="14sp" />

</LinearLayout>
